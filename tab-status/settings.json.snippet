{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh white" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh red" } ] },
      { "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh remind-name" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh green" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Agent", "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh bg-inc" } ] },
      { "matcher": "AskUserQuestion", "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh blue" } ] }
    ],
    "PostToolUse": [
      { "matcher": "AskUserQuestion", "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh red" } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh bg-dec" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "$HOME/.claude/scripts/tab.sh session-end" } ] }
    ]
  }
}
